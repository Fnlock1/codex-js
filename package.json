{
  "name": "qoder-open",
  "version": "0.1.0",
  "private": true,
  "description": "Electron, Vue, and Monaco desktop code editor.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev:desktop": "pnpm --filter @qoder-open/desktop dev",
    "build:desktop": "pnpm --filter @qoder-open/desktop build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
